{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NewSessionResponse",
  "required": [
    "authenticationToken",
    "bearerToken"
  ],
  "type": "object",
  "properties": {
    "errorMessage": {
      "type": "string",
      "nullable": true
    },
    "authenticationToken": {
      "type": "string",
      "format": "uuid"
    },
    "bearerToken": {
      "minLength": 1,
      "type": "string"
    }
  },
  "additionalProperties": false
}