{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TranslateStudyRequest",
  "required": [
    "studyKey",
    "targetLanguageCode"
  ],
  "type": "object",
  "properties": {
    "studyKey": {
      "type": "integer",
      "description": "Key of study",
      "format": "int32"
    },
    "targetLanguageCode": {
      "minLength": 1,
      "type": "string",
      "description": "Code of target language"
    }
  },
  "additionalProperties": false,
  "description": "Request for translating study"
}